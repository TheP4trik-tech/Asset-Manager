<div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center gap-2 mb-6 text-sm text-white/40">
      <%= link_to "Budovy", buildings_path, class: "hover:text-white transition-colors" %>
      <span>/</span>
      <%= link_to @asset.room.building.name, building_path(@asset.room.building), class: "hover:text-white transition-colors" %>
      <span>/</span>
      <%= link_to @asset.room.name, room_path(@asset.room), class: "hover:text-white transition-colors" %>
      <span>/</span>
      <span class="text-white/70"><%= @asset.name %></span>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <div class="flex items-center gap-3 mb-1">
          <h1 class="text-2xl font-semibold text-white"><%= @asset.name %></h1>
          <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
            <%= @asset.code %>
          </span>
        </div>
        <p class="text-sm text-white/50">Detail majetku</p>
      </div>
      <div class="flex flex-col items-center gap-4 p-4 bg-white/5 border border-white/10 rounded-2xl w-fit">
        <% cache @asset do %>
        <div class="p-2 bg-white rounded-lg shadow-inner">
          <%= image_tag qr_code_asset_path(@asset), class: "w-32 h-32 block", alt: "QR kód" %>
        </div>
          <% end %>

        <%= link_to qr_code_asset_path(@asset, format: :svg),
                    download: "QR_asset_#{@asset.id}.svg",
                    class: "inline-flex items-center gap-2 px-4 py-2 bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium rounded-xl transition-all shadow-lg shadow-[#7F77DD]/20 group" do %>

          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white/80 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>

          <span>Stáhnout QR štítek</span>
        <% end %>
      </div>


      <div class="flex items-center gap-2">
        <% if can? :update, @asset %>
          <%= link_to "Upravit", edit_asset_path(@asset),
                      class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors" %>
        <% end %>
        <% if can? :destroy, @asset %>
          <%= button_to "Smazat", asset_path(@asset), method: :delete,
                        data: { confirm: "Opravdu chcete smazat tento majetek?" },
                        class: "px-4 py-2 rounded-lg bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm font-medium transition-colors cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

      <div class="lg:col-span-2 rounded-xl border border-white/10 overflow-hidden h-fit">
        <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
          <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Základní informace</h2>
        </div>
        <div class="divide-y divide-white/5">

          <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Název položky</p>
              <p class="text-sm text-white font-medium"><%= @asset.name %></p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Kód</p>
              <p class="text-sm font-mono text-[#a9a4ed]"><%= @asset.code %></p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Datum pořízení</p>
              <p class="text-sm text-white"><%= @asset.purchase_date.strftime("%d. %m. %Y") %></p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Poslední kontrola</p>
              <p class="text-sm text-white"><%= @asset.last_check_date.strftime("%d. %m. %Y") %></p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Pořizovací cena</p>
              <p class="text-sm font-medium text-[#a9a4ed]">
                <%= @asset.purchase_price ? number_to_currency(@asset.purchase_price, strip_insignificant_zeros: true) : "—" %>
              </p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Poznámka</p>
              <p class="text-sm text-white break-words">
                <%= @asset.note.presence || "—" %>
              </p>
            </div>
          </div>

        </div>
      </div>

      <div class="rounded-xl border border-white/10 overflow-hidden h-fit">
        <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
          <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Umístění</h2>
        </div>
        <div class="divide-y divide-white/5">
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Místnost</p>
            <p class="text-sm text-white font-medium">
              <%= link_to @asset.room.name, room_path(@asset.room), class: "hover:text-[#7F77DD] transition-colors" %>
            </p>
          </div>
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Budova</p>
            <p class="text-sm text-white">
              <%= link_to @asset.room.building.name, building_path(@asset.room.building), class: "hover:text-[#7F77DD] transition-colors" %>
            </p>
          </div>
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Správce budovy</p>
            <p class="text-sm text-white/70"><%= @asset.room.building.user.to_s %></p>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-12 mb-6">
      <h2 class="text-lg font-semibold text-white">Přílohy a dokumenty</h2>
      <p class="text-sm text-white/50 mt-1">Faktury, návody nebo fotky vázané k tomuto majetku</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
      <div class="flex flex-col">
        <%= render "attachments/list", asset: @asset %>
      </div>
      <% if can? :manage, @asset %>
        <div class="flex flex-col">
          <%= render "attachments/form", asset: @asset %>
        </div>
      <% end %>
    </div>

  </div>
</div>