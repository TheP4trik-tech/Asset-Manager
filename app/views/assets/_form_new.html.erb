<%= form_with model: @asset, data: { controller: "asset-form", asset_form_rooms_value: @rooms.to_json(only: [:id, :name, :building_id]) } do |f| %>

  <% if @asset.errors.any? %>
    <div class="mb-6 px-5 py-4 rounded-xl bg-red-500/10 border border-red-500/20">
      <% @asset.errors.full_messages.each do |msg| %>
        <p class="text-sm text-red-400"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

    <div class="lg:col-span-2 rounded-xl border border-white/10 overflow-hidden h-fit">
      <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
        <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Základní informace</h2>
      </div>
      <div class="divide-y divide-white/5">

        <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Název položky <span class="text-red-400">*</span></p>
            <%= f.text_field :name,
                             class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                             placeholder: "Název majetku" %>
          </div>
          <div class="px-5 py-4 flex flex-col justify-center">
            <p class="text-xs text-white/40 mb-1">Kód</p>
            <% if @asset.persisted? %>
              <p class="text-sm font-mono text-[#a9a4ed]"><%= @asset.code %></p>
            <% else %>
              <p class="text-sm text-white/30 italic">Generuje se automaticky</p>
            <% end %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Datum pořízení <span class="text-red-400">*</span></p>
            <%= f.date_field :purchase_date,
                             class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors [&::-webkit-calendar-picker-indicator]:invert-[0.6]" %>
          </div>
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Poslední kontrola <span class="text-red-400">*</span></p>
            <%= f.date_field :last_check_date,
                             class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors [&::-webkit-calendar-picker-indicator]:invert-[0.6]" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Pořizovací cena (KČ)</p>
            <%= f.number_field :purchase_price, step: 0.01,
                               class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                               placeholder: "0.00" %>
          </div>
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Poznámka <span class="text-white/25">(volitelné)</span></p>
            <%= f.text_area :note, rows: 3,
                            class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors resize-none",
                            placeholder: "Doplňující poznámka..." %>
          </div>
        </div>

      </div>
    </div>

    <div class="rounded-xl border border-white/10 overflow-hidden h-fit">
      <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
        <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Umístění</h2>
      </div>
      <div class="divide-y divide-white/5">

        <div class="px-5 py-4">
          <p class="text-xs text-white/40 mb-1">Budova <span class="text-red-400">*</span></p>
          <%= select_tag :building_id,
                         options_from_collection_for_select(@buildings, :id, :name, current_user.buildings.first),
                         data: {
                           asset_form_target: "buildingSelect",
                           action: "change->asset-form#filterRooms"
                         },
                         class: "w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition-colors" %>  </div>
      </div>

        <div class="px-5 py-4">
          <p class="text-xs text-white/40 mb-1">Místnost <span class="text-red-400">*</span></p>
          <%= f.select :room_id,
                       @rooms.map { |r| [r.name, r.id] },
                       { selected: @asset.room_id },
                       { data: { asset_form_target: "roomSelect" },
                         class: "w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500 transition-colors" } %>
        </div>

        <% if @asset.persisted? %>
          <div class="px-5 py-4">
            <p class="text-xs text-white/40 mb-1">Správce budovy</p>
            <p class="text-sm text-white/70"><%= @asset.room.building.user.to_s %></p>
          </div>
        <% end %>

      </div>
    </div>

  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Zrušit", @asset.persisted? ? asset_path(@asset) : assets_path,
                class: "px-4 py-2 rounded-lg text-white/50 hover:text-white text-sm transition-colors" %>
    <%= f.submit @asset.persisted? ? "Uložit změny" : "Vytvořit majetek",
                 class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors cursor-pointer" %>
  </div>

<% end %>