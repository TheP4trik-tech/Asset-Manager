<nav style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);" class="border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">


      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-[#7F77DD] flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 16 16">
            <rect x="2" y="2" width="5" height="5" rx="1" fill="white"/>
            <rect x="9" y="2" width="5" height="5" rx="1" fill="white"/>
            <rect x="2" y="9" width="5" height="5" rx="1" fill="white"/>
            <rect x="9" y="9" width="5" height="5" rx="1" fill="white"/>
          </svg>
        </div>
        <%= link_to "Asset Manager", root_path, class: "text-sm font-medium text-white" %>
      </div>


      <div class="hidden md:flex items-center gap-1">
        <%= link_to "Budovy", buildings_path,
                    class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{controller_name == 'buildings' ? 'bg-white/15 text-white font-medium' : 'text-white/60 hover:text-white hover:bg-white/10'}" %>
        <%= link_to "Místnosti", rooms_path,
                    class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{controller_name == 'rooms' ? 'bg-white/15 text-white font-medium' : 'text-white/60 hover:text-white hover:bg-white/10'}" %>
        <%= link_to "Majetek", assets_path,
                    class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{controller_name == 'assets' ? 'bg-white/15 text-white font-medium' : 'text-white/60 hover:text-white hover:bg-white/10'}" %>
          <%= link_to "Uživatelé", users_path,
                      class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{controller_name == 'users' ? 'bg-white/15 text-white font-medium' : 'text-white/60 hover:text-white hover:bg-white/10'}" %>
        <%= link_to "Audity", audit_logs_path,
                    class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{controller_name == 'audit_logs' ? 'bg-white/15 text-white font-medium' : 'text-white/60 hover:text-white hover:bg-white/10'}" %>
      </div>

      <div class="hidden md:flex items-center gap-2">
        <%= link_to user_path(current_user),
                    class: "flex items-center gap-2 px-3 py-1.5 hover:bg-white/10 rounded-lg transition-colors" do %>
          <div class="w-6 h-6 rounded-full bg-[#7F77DD] flex items-center justify-center text-white text-xs font-medium">
            <%= current_user.first_name&.first&.upcase %><%= current_user.last_name&.first&.upcase %>
          </div>
          <span class="text-sm text-white/70"><%= current_user.first_name %></span>
        <% end %>

        <%= button_to "Odhlásit se", destroy_user_session_path, method: :delete,
                      class: "px-3 py-1.5 text-sm text-white/60 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-colors cursor-pointer" %>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors">
        <svg id="icon-open" class="w-5 h-5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 text-white/70 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

    </div>
  </div>


  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 px-4 py-3 space-y-1">
    <%= link_to "Budovy", buildings_path,
                class: "block px-3 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors" %>
    <%= link_to "Místnosti", rooms_path,
                class: "block px-3 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors" %>
    <%= link_to "Majetek", assets_path,
                class: "block px-3 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors" %>

      <%= link_to "Uživatelé", users_path,
                  class: "block px-3 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors" %>

    <div class="border-t border-white/10 pt-2 mt-2 space-y-1">
      <div class="flex items-center gap-2 px-3 py-2">
        <div class="w-6 h-6 rounded-full bg-[#7F77DD] flex items-center justify-center text-white text-xs font-medium">
          <%= current_user.first_name&.first&.upcase %><%= current_user.last_name&.first&.upcase %>
        </div>
      </div>
      <%= link_to "Profil", user_path(current_user),
                  class: "block px-3 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors" %>
      <%= button_to "Odhlásit se", destroy_user_session_path, method: :delete,
                    class: "w-full text-left px-3 py-2 text-sm text-red-400/80 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-colors cursor-pointer" %>
    </div>
  </div>
</nav>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
        iconOpen.classList.toggle("hidden");
        iconClose.classList.toggle("hidden");
    });
</script>