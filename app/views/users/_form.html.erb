<div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center gap-2 mb-6 text-sm text-white/40">
      <%= link_to "Uživatelé", users_path, class: "hover:text-white transition-colors" %>
      <span>/</span>
      <%= link_to @user.to_s, user_path(@user), class: "hover:text-white transition-colors" %>
      <span>/</span>
      <span class="text-white/70">Úprava</span>
    </div>

    <div class="flex items-center gap-3 mb-8">
      <h1 class="text-2xl font-semibold text-white">Úprava: <%= @user.to_s %></h1>
      <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
        <%= @user.code %>
      </span>
    </div>

    <%= form_with model: @user do |f| %>

      <% if @user.errors.any? %>
        <div class="mb-6 px-5 py-4 rounded-xl bg-red-500/10 border border-red-500/20">
          <% @user.errors.full_messages.each do |msg| %>
            <p class="text-sm text-red-400"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

        <div class="lg:col-span-2 rounded-xl border border-white/10 overflow-hidden h-fit">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Osobní údaje</h2>
          </div>
          <div class="divide-y divide-white/5">

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Jméno <span class="text-red-400">*</span></p>
                <%= f.text_field :first_name,
                                 class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                                 placeholder: "Jméno" %>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Příjmení <span class="text-red-400">*</span></p>
                <%= f.text_field :last_name,
                                 class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                                 placeholder: "Příjmení" %>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">E-mail <span class="text-red-400">*</span></p>
                <%= f.email_field :email,
                                  class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                                  placeholder: "email@example.com" %>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Telefon <span class="text-white/25">(volitelné)</span></p>
                <%= f.telephone_field :phone,
                                      class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                                      placeholder: "+420 000 000 000" %>
              </div>
            </div>

          </div>
        </div>

        <div class="rounded-xl border border-white/10 overflow-hidden h-fit">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Systémové údaje</h2>
          </div>
          <div class="divide-y divide-white/5">

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Kód</p>
              <p class="text-sm font-mono text-[#a9a4ed] mt-1"><%= @user.code %></p>
            </div>

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Role</p>
              <% if current_user.super_admin? && @user != current_user %>
                <%= f.select :role,
                             User.roles.keys.map { |r| [r.humanize, r] },
                             { selected: @user.role },
                             { class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors" } %>
              <% else %>
                <span class="inline-block px-2 py-0.5 rounded-md text-xs font-medium bg-purple-500/20 text-purple-300">
                  <%= @user.role %>
                </span>
              <% end %>
            </div>

          </div>
        </div>

      </div>

      <div class="flex items-center justify-end gap-3">
        <%= link_to "Zrušit", user_path(@user),
                    class: "px-4 py-2 rounded-lg text-white/50 hover:text-white text-sm transition-colors" %>
        <%= f.submit "Uložit změny",
                     class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors cursor-pointer" %>
      </div>

    <% end %>

  </div>
</div>