<div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
  <%= turbo_stream_from "buildings" %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-semibold text-white">Budovy</h1>
        <p class="text-sm text-white/50 mt-1">Přehled všech budov v systému</p>
      </div>
      <% if can? :create, Building %>
        <%= link_to "+ Přidat budovu", new_building_path,
                    class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors" %>
      <% end %>
    </div>

    <%= search_form_for @q, model: Building, method: :get,
                        html: { class: "mb-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center" } do |f| %>

      <div class="flex-1 w-full sm:max-w-xs">
        <%= f.label :name_cont, "Hledat podle názvu", class: "sr-only" %>
        <%= f.text_field :name_cont,
                         placeholder: "Hledat podle názvu…",
                         class: "w-full px-4 py-2 rounded-lg bg-white/10 border border-white/15
                      text-white placeholder-white/40 text-sm
                      focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD]
                      transition-colors" %>
      </div>

      <%= f.submit "Hledat",
                   class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white
                    text-sm font-medium transition-colors cursor-pointer" %>
    <% end %>

    <div class="overflow-x-auto rounded-xl border border-white/10">
      <table class="min-w-full text-sm">

        <thead>
        <tr style="background: rgba(255,255,255,0.07);">
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :name, 'NÁZEV') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :code, 'kód') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :contact_email, 'e-mail') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :contact_phone, 'telefon') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :city, 'město') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :street, 'ulice') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider whitespace-nowrap"><%= sort_link(@q, :building_date, 'Datum budovy') %></th>
        </tr>
        </thead>
        <tbody class="divide-y divide-white/5" id="buildings">

        <% if @buildings.any? %>
          <% @buildings.each do |building| %>
              <%= render "building", building: building %>
            <%end %>
        <% else %>
          <tr>
            <td colspan="7" class="px-4 py-12 text-center text-white/40 text-sm">
              Žádné budovy nebyly nalezeny.
            </td>
          </tr>
        <% end %>

        </tbody>

      </table>
    </div>

    <div class="mt-6">
      <%== @pagy.series_nav %>
    </div>

  </div>
</div>