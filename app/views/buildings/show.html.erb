  <div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <div class="flex items-center gap-2 mb-6 text-sm text-white/40">
        <%= link_to "Budovy", buildings_path, class: "hover:text-white transition-colors" %>
        <span>/</span>
        <span class="text-white/70"><%= @building.name %></span>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-2xl font-semibold text-white"><%= @building.name %></h1>
            <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
              <%= @building.code %>
            </span>
          </div>
          <p class="text-sm text-white/50">Detail budovy</p>
        </div>

        <div class="flex items-center gap-2">
          <% if can? :update, @building %>
          <%= link_to "Upravit", edit_building_path(@building),
                      class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors" %>
            <% end %>
          <% if can? :destroy, @building %>
          <%= button_to "Smazat", building_path(@building), method: :delete,
                        data: { confirm: "Opravdu chcete smazat tuto budovu?" },
                        class: "px-4 py-2 rounded-lg bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm font-medium transition-colors cursor-pointer" %>
            <% end %>
        </div>

      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">


        <div class="lg:col-span-2 rounded-xl border border-white/10 overflow-hidden">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Základní informace</h2>
          </div>
          <div class="divide-y divide-white/5">

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Název</p>
                <p class="text-sm text-white font-medium"><%= @building.name %></p>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Kód</p>
                <p class="text-sm font-mono text-[#a9a4ed]"><%= @building.code %></p>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Kontaktní e-mail</p>
                <p class="text-sm text-white"><%= @building.contact_email %></p>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Kontaktní telefon</p>
                <p class="text-sm text-white"><%= @building.contact_phone%></p>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Datum vytvoření budovy</p>
                <p class="text-sm text-white"><%= @building.building_date.strftime("%d. %m. %Y") %></p>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Celkové množství místností</p>
                <p class="text-sm text-white"><%= @building.rooms.count %></p>
              </div>
            </div>

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Celková hodnota evidovaného majetku</p>
              <p class="text-sm font-medium text-[#a9a4ed]">
                <%= @building.assets.any? ?   @building.assets.sum(:purchase_price).to_s + "KČ" : "Bez majetku" %>
              </p>
            </div>

          </div>
        </div>


        <div class="rounded-xl border border-white/10 overflow-hidden">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Adresa</h2>
          </div>
          <div class="divide-y divide-white/5">
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Ulice</p>
              <p class="text-sm text-white"><%= @building.street.presence || "—" %></p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Město</p>
              <p class="text-sm text-white"><%= @building.city.presence || "—" %></p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">PSČ</p>
              <p class="text-sm text-white"><%= @building.zip_code.presence || "—" %></p>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Správce</p>
              <p class="text-sm text-white"><%= @building.user.to_s %></p>
            </div>
          </div>
        </div>

      </div>


      <div class="rounded-xl border border-white/10 overflow-hidden">
        <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Místnosti</h2>
          <span class="text-xs text-white/40"><%= @building.rooms.count %> místností</span>
        </div>

        <% if @building.rooms.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead>
              <tr style="background: rgba(255,255,255,0.04);">
                <th class="px-4 py-3 text-left text-xs font-semibold text-white/40 uppercase tracking-wider">Název</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white/40 uppercase tracking-wider">Kód</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white/40 uppercase tracking-wider hidden sm:table-cell">Datum vytvoření</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white/40 uppercase tracking-wider hidden sm:table-cell">Celková cena majetku</th>
                <th class="px-4 py-3"></th>
              </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
              <% @building.rooms.each do |room| %>
                <tr class="hover:bg-white/5 transition-colors group cursor-pointer"
                    onclick="window.location='<%= room_path(room) %>'">
                  <td class="px-4 py-3 text-white font-medium whitespace-nowrap"><%= room.name %></td>
                  <td class="px-4 py-3 whitespace-nowrap">
                      <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
                        <%= room.code %>
                      </span>
                  </td>
                  <td class="px-4 py-3 text-white/60 whitespace-nowrap hidden sm:table-cell">
                    <%= room.room_date.strftime("%d. %m. %Y") %>
                  </td>
                  <td class="px-4 py-3 text-white/60 whitespace-nowrap hidden sm:table-cell">
                    <%=  room.assets.present? ? room.assets.sum(:purchase_price).to_s + "KČ" : "Bez majetku" %>
                  </td>
                  <td class="px-4 py-3 text-right whitespace-nowrap">
                    <%= link_to "Detail →", room_path(room), class: "text-xs text-[#7F77DD] hover:underline" %>
                  </td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-5 py-12 text-center text-white/40 text-sm">
            Tato budova zatím nemá žádné místnosti.
          </div>
        <% end %>
      </div>

    </div>
  </div>