<% if resource.errors.any? %>
  <div class="mb-4 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
    <p class="text-xs font-medium text-red-600 mb-1">
      <%= pluralize(resource.errors.count, "chyba", "chyb") %> <%= resource.errors.count == 1 ? "zabránila" : "zabránily" %> uložení:
    </p>
    <ul class="list-disc list-inside space-y-0.5">
      <% resource.errors.full_messages.each do |msg| %>
        <li class="text-xs text-red-500"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
