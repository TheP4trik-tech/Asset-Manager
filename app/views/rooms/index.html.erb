<div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">


    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-semibold text-white">Místnosti</h1>
        <p class="text-sm text-white/50 mt-1">Kompletní přehled všech místností napříč budovami</p>
      </div>
      <% if can? :create, Room %>
        <%= link_to "+ Přidat místnost", new_room_path,
                    class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors" %>
      <% end %>
    </div>

       <%= search_form_for @q, class: "mb-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center" do |f| %>
        <div class="flex-1 w-full sm:max-w-xs">
          <%= f.text_field :name_or_code_cont,
                           placeholder: "Hledat místnost...",
                           class: "w-full px-4 py-2 rounded-lg bg-white/10 border border-white/15 text-white placeholder-white/40 text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors" %>
        </div>
        <%= f.submit "Hledat", class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors cursor-pointer" %>
      <% end %>

    <div class="overflow-x-auto rounded-xl border border-white/10">
      <table class="min-w-full text-sm">
        <thead>
        <tr style="background: rgba(255,255,255,0.07);">
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider"><%= sort_link(@q, :name, 'název') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider"><%= sort_link(@q, :code, 'kód') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider hidden sm:table-cell"><%= sort_link(@q, :room_date, 'datum místnosti') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider"><%= sort_link(@q, :building.name, 'název budovy') %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/50 uppercase tracking-wider hidden md:table-cell text-right"> <%= sort_link(@q, :assets_sum, 'cena majetku') %></th>
        </tr>
        </thead>

        <tbody class="divide-y divide-white/5">
        <% if @rooms.present? %>
          <% @rooms.each do |room| %>
            <tr class="hover:bg-white/5 transition-colors group cursor-pointer"
                onclick="window.location='<%= room_path(room) %>'">

              <td class="px-4 py-3 text-white font-medium whitespace-nowrap">
                <%= room.name %>
              </td>

              <td class="px-4 py-3 whitespace-nowrap">
                  <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
                    <%= room.code %>
                  </span>
              </td>

              <td class="px-4 py-3 text-white/60 whitespace-nowrap hidden sm:table-cell">
                <%= room.room_date.strftime("%d. %m. %Y")%>
              </td>

              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <span class="text-white/70"><%= room.building.name %></span>
                </div>
              </td>

              <td class="px-4 py-3 text-right whitespace-nowrap hidden md:table-cell font-medium text-[#a9a4ed]">
                <% room_asset_sum = room.assets.sum(&:purchase_price) %>
                <%=  room_asset_sum > 0  ? number_to_currency(room_asset_sum,  strip_insignificant_zeros: true) : "Bez majetku" %>
              </td>

            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-white/40 text-sm">
              Nebyly nalezeny žádné místnosti.
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
    <div><%== @pagy.series_nav %></div>

  </div>
</div>