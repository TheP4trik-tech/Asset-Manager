<div class="min-h-screen" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <div class="flex items-center gap-2 mb-6 text-sm text-white/40">
      <%= link_to "Budovy", buildings_path, class: "hover:text-white transition-colors" %>
      <span>/</span>
      <%= link_to @room.building.name, building_path(@room.building), class: "hover:text-white transition-colors" %>
      <span>/</span>
      <%= link_to @room.name, room_path(@room), class: "hover:text-white transition-colors" %>
      <span>/</span>
      <span class="text-white/70">Úprava</span>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <div class="flex items-center gap-3 mb-1">
          <h1 class="text-2xl font-semibold text-white">Úprava: <%= @room.name %></h1>
          <span class="inline-block px-2 py-0.5 rounded-md bg-[#7F77DD]/20 text-[#a9a4ed] font-mono text-xs tracking-wide">
            <%= @room.code %>
          </span>
        </div>
        <p class="text-sm text-white/50">Editace místnosti</p>
      </div>
    </div>

    <%= form_with model: @room do |f| %>

      <% if @room.errors.any? %>
        <div class="mb-6 px-5 py-4 rounded-xl bg-red-500/10 border border-red-500/20">
          <% @room.errors.full_messages.each do |msg| %>
            <p class="text-sm text-red-400"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

        <div class="lg:col-span-2 rounded-xl border border-white/10 overflow-hidden h-fit">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Základní informace</h2>
          </div>
          <div class="divide-y divide-white/5">

            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Název místnosti <span class="text-red-400">*</span></p>
                <%= f.text_field :name,
                                 class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors",
                                 placeholder: "Název místnosti" %>
              </div>
              <div class="px-5 py-4">
                <p class="text-xs text-white/40 mb-1">Kód</p>
                <p class="text-sm font-mono text-[#a9a4ed] mt-2"><%= @room.code %></p>
              </div>
            </div>

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Datum vytvoření <span class="text-red-400">*</span></p>
              <%= f.date_field :room_date,
                               class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors [&::-webkit-calendar-picker-indicator]:invert-[0.6]" %>
            </div>

          </div>
        </div>

        <div class="rounded-xl border border-white/10 overflow-hidden h-fit">
          <div style="background: rgba(255,255,255,0.07);" class="px-5 py-3 border-b border-white/10">
            <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider">Umístění</h2>
          </div>
          <div class="divide-y divide-white/5">

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Budova <span class="text-red-400">*</span></p>
              <%= f.select :building_id,
                           options_from_collection_for_select(@buildings, :id, :name, @room.building_id),
                           {},
                           { class: "w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#7F77DD]/60 focus:border-[#7F77DD] transition-colors" } %>
            </div>

            <div class="px-5 py-4">
              <p class="text-xs text-white/40 mb-1">Správce budovy</p>
              <p class="text-sm text-white/70"><%= @room.building.user.to_s %></p>
            </div>

          </div>
        </div>

      </div>

      <div class="flex items-center justify-end gap-3">
        <%= link_to "Zrušit", room_path(@room),
                    class: "px-4 py-2 rounded-lg text-white/50 hover:text-white text-sm transition-colors" %>
        <%= f.submit "Uložit změny",
                     class: "px-4 py-2 rounded-lg bg-[#7F77DD] hover:bg-[#6c64c8] text-white text-sm font-medium transition-colors cursor-pointer" %>
      </div>

    <% end %>

  </div>
</div>